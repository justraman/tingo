// Tambola Cloudflare worker — cron-driven draw poker + D1 game indexer.
//
// Two cron triggers dispatch inside src/index.ts on `controller.cron`:
//   "* * * * *"   → drawer: ticks drawNumber every DRAW_INTERVAL_SECONDS (6 s)
//                   within the minute (Cloudflare crons can't fire sub-minute).
//   "*/5 * * * *" → indexer: snapshots every game into the D1 database.
{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "tambola-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  // Crons disabled 2026-07-20: draws/announcements/indexing moved to the
  // polkadot-flow runner (runner/loop.ts + ~/Work/polkadot-flow PR #31).
  // The worker stays deployed only for the read-only GET /games endpoint.
  // To re-enable the old behavior: restore ["* * * * *", "*/5 * * * *"].
  "triggers": {
    "crons": []
  },
  "vars": {
    "CHAIN_RPC": "wss://paseo-asset-hub-next-rpc.polkadot.io",
    // People chain node exposing the statement_* RPC — chat announcements
    // publish here in local mode (no host).
    "STATEMENT_RPC": "wss://paseo-people-next-system-rpc.polkadot.io",
    "TAMBOLA_ADDRESS": "0x6b383c507a7cde394279ec598038bdf9ad0681e7",
    // Must be a Revive-mapped account: the runtime rejects dry-runs from
    // unmapped origins. The dev deploy signer is mapped by the deploy itself.
    "READ_ONLY_ORIGIN": "5DfhGyQdFobKM8NsWvEeAKk5EQQgYe9AydgJ7rMB6E1EqRzV"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "tambola-index",
      "database_id": "06969f79-454f-4fd5-884f-9727ad13506f"
    }
  ]
}
