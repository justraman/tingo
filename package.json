{
  "name": "tambola-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "papi:install": "papi",
    "papi:add": "papi add paseo_asset_hub -w wss://paseo-asset-hub-next-rpc.polkadot.io",
    "test:contract": "forge test -vv",
    "cf:typecheck": "tsc --noEmit -p cloudflare",
    "cf:dev": "wrangler dev --config cloudflare/wrangler.jsonc --test-scheduled",
    "cf:deploy": "wrangler deploy --config cloudflare/wrangler.jsonc",
    "compile:contract": "forge build",
    "deploy:contract": "playground contract deploy --signer dev",
    "deploy:app": "npm run build && playground deploy --signer dev --domain tambola-game --buildDir ./out --no-build --playground"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@novasamatech/sdk-statement": "^0.6.0",
    "@novasamatech/statement-store": "^0.8.10",
    "@parity/product-sdk-contracts": "0.8.3",
    "@parity/product-sdk-statement-store": "^0.5.0",
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "@polkadot-labs/hdkd": "^0.0.29",
    "@polkadot-labs/hdkd-helpers": "^0.0.31",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.2",
    "@tanstack/react-query": "^5.90.0",
    "@use-truapi/core": "^0.1.0",
    "@use-truapi/react": "^0.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "motion": "^12.42.2",
    "polkadot-api": "^2.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@polkadot-api/cli": "^0.18.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.0",
    "vite": "^5.4.10",
    "wrangler": "^4.108.0"
  }
}
